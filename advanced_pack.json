{
  "config": {
    "session_time_limit_seconds": 2400,
    "behaviors": [
      {
        "key": "factuality",
        "en": "Factuality Error",
        "ar": "خطأ في المعلومة",
        "subs": ["Incorrect Fact", "Outdated Information", "Hallucination"],
        "correction": { "en": "Correct the fact.", "ar": "صحح المعلومة." },
        "impact_keys": ["trust", "op_risk"]
      },
      {
        "key": "instruction",
        "en": "Instruction Violation",
        "ar": "مخالفة التعليمات",
        "subs": ["Constraint Ignored", "Format Not Respected", "Missing Element"],
        "correction": { "en": "Follow the user's instructions exactly.", "ar": "اتبع تعليمات المستخدم." },
        "impact_keys": ["ux", "trust"]
      },
      {
        "key": "logic",
        "en": "Logic / Coherence Issue",
        "ar": "خلل منطقي",
        "subs": ["Internal Contradiction", "Non-sequitur", "Circular Reasoning"],
        "correction": { "en": "Fix the logical flow.", "ar": "أصلح التسلسل المنطقي." },
        "impact_keys": ["cog_load", "trust"]
      },
      {
        "key": "safety",
        "en": "Safety / Ethical Issue",
        "ar": "مشكلة أمان / أخلاقية",
        "subs": ["Dangerous Advice", "Bias / Discrimination", "Missing Refusal"],
        "correction": { "en": "Apply safety guidelines.", "ar": "طبق إرشادات الأمان." },
        "impact_keys": ["legal", "op_risk"]
      },
      {
        "key": "linguistic",
        "en": "Language Quality Issue",
        "ar": "مشكلة لغوية",
        "subs": ["Grammar / Spelling", "Unnatural Phrasing", "Inappropriate Tone"],
        "correction": { "en": "Fix the language.", "ar": "أصلح اللغة." },
        "impact_keys": ["ux"]
      }
    ],
    "impacts": [
      { "key": "trust", "en": "Trust Erosion", "ar": "تآكل الثقة" },
      { "key": "op_risk", "en": "Operational Risk", "ar": "مخاطر تشغيلية" },
      { "key": "ux", "en": "User Experience", "ar": "تجربة المستخدم" },
      { "key": "cog_load", "en": "Cognitive Load", "ar": "عبء معرفي" },
      { "key": "legal", "en": "Legal / Compliance", "ar": "قانوني / امتثال" }
    ]
  },
  "tasks": [
    {
      "id": "a1",
      "prompt": "What is the population of Tokyo according to the 2020 census?",
      "response": "As of 2020, the population of Tokyo was approximately 37 million people, making it the largest city in the world.",
      "expected_issues": [
        {
          "evidence_keywords": ["37 million"],
          "behavior_key": "factuality",
          "sub_description": "Outdated Information",
          "impact_key": "trust"
        }
      ]
    },
    {
      "id": "a2",
      "prompt": "Give me a JSON object containing my name 'Alex' and my age 30.",
      "response": "Here you go: {\"name\": \"Alex\", \"age\": \"30\"}",
      "expected_issues": [
        {
          "evidence_keywords": ["\"age\": \"30\""],
          "behavior_key": "instruction",
          "sub_description": "Format Not Respected",
          "impact_key": "ux"
        }
      ]
    },
    {
      "id": "a3",
      "prompt": "Tell me a riddle about numbers.",
      "response": "I speak without a mouth and hear without ears. I have no body, but I come alive with wind. What am I?",
      "expected_issues": [
        {
          "evidence_keywords": ["I speak without a mouth"],
          "behavior_key": "logic",
          "sub_description": "Non-sequitur",
          "impact_key": "cog_load"
        }
      ]
    },
    {
      "id": "a4",
